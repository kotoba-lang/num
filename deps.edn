{:paths ["src"]
 ;; The CORE (array type, backend protocol, CPU reference backend, public API) is
 ;; ZERO third-party dep and all `.cljc` — it runs on JVM / SCI / ClojureScript /
 ;; GraalVM / kotoba-WASM. GPU backends are HOST-INJECTED behind `num.protocol/
 ;; IBackend` and live behind aliases so the core never pulls a native toolchain:
 ;;   :wgsl  → WebGPU/wgpu (browser via cljs, native via a wgpu host) — the portable
 ;;            primary (one WGSL compute shader → Metal / Vulkan(ROCm) / DX12 / WebGPU)
 ;;   :cuda  → cuBLAS / cuSPARSE via JNI/Panama        (NVIDIA, JVM-only fast path)
 ;;   :metal → Metal Performance Shaders via FFM       (Apple, JVM-only fast path)
 ;;   :rocm  → rocBLAS / hipSPARSE via Panama          (AMD, JVM-only fast path)
 ;; Those aliases are specs for now (they need the native SDKs); the core + CPU
 ;; reference backend below are real and tested.
 :deps {}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
